# Public Supabase project variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_BUILD_CODE=local-dev

# Server-side only (Next.js API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
REPORTS_TRIGGER_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
REPORT_TEMPLATE_VERSION=v2

# Cloud Run worker environment (workers/report-worker)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
REPORTS_BUCKET=inspection-reports
REPORT_ASSETS_BUCKET=inspection-report-assets
WORKER_ID=cloud-run-report-worker
POLL_INTERVAL_MS=5000
CLAIM_BATCH_SIZE=1
MAX_SUMMARY_IMAGES=4
MAX_FULL_IMAGES=12
SUMMARY_RENDER_TIMEOUT_MS=45000
FULL_RENDER_TIMEOUT_MS=180000
